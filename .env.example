# Facebook Credentials
FACEBOOK_EMAIL=your_email@example.com
FACEBOOK_PASSWORD=your_password

# 2FA Settings (if using authenticator app)
FACEBOOK_2FA_SECRET=your_2fa_secret_key

# Gemini API Key for image analysis
GEMINI_API_KEY=AIzaSyDiyBs75bDIsM7kTl36DT0mccOVFFfETiI

# Browser Settings
HEADLESS=False
IMPLICIT_WAIT=10

# Perfil persistente de Chrome -> la sesion (login + 2FA) sobrevive entre
# arranques. IMPRESCINDIBLE para el responder 24/7 (no pide 2FA cada vez).
# Ej Linux/Pi: /home/USUARIO/.fb_profile   |  Windows: C:\fb_profile
CHROME_PROFILE_DIR=
# Binario de Chrome (solo si no esta en el PATH; util en ARM/headless).
CHROME_BINARY=
# Velocidad humana: 1.0 normal, >1 mas lento (Pi modesto), <1 mas rapido.
HUMAN_SPEED=1.0

# Image Analysis Settings
AI_MODEL_IMAGE=gemini-2.5-flash
AI_MODEL_CHAT=gemini-2.5-flash
MAX_IMAGE_SIZE=2048

# --- Responder automatico de Messenger ---
# Intervalo ALEATORIO entre rondas de respuestas (minutos). NO cada 10s.
RESPONDER_MIN_MINUTES=3
RESPONDER_MAX_MINUTES=8
RESPONDER_MAX_THREADS_PER_ROUND=3
# Contexto del negocio para la IA (vacio = usa el default de settings.py).
BUSINESS_CONTEXT=

# --- Grupos de Facebook ---
# URLs separadas por coma. Publicar en estos:
FACEBOOK_GROUPS=
# Unirse a estos:
FACEBOOK_GROUPS_TO_JOIN=
# Pausa ALEATORIA entre publicaciones a grupos (minutos), anti-spam.
GROUP_POST_MIN_MINUTES=4
GROUP_POST_MAX_MINUTES=12
