# ===== Facebook =====
FACEBOOK_EMAIL=your_email@example.com
FACEBOOK_PASSWORD=your_password
# 2FA (opcional, si usas app de autenticador). Si lo dejas vacio, aprobaras desde el celular.
FACEBOOK_2FA_SECRET=

# ===== Gemini (consiguela en https://aistudio.google.com/apikey) =====
GEMINI_API_KEY=tu_api_key_aqui
AI_MODEL_IMAGE=gemini-2.5-flash
AI_MODEL_CHAT=gemini-2.5-pro
MAX_IMAGE_SIZE=2048

# ===== Navegador =====
HEADLESS=False
IMPLICIT_WAIT=10
# Perfil persistente (mantiene la sesion para no re-loguear cada vez)
USER_DATA_DIR=browser_data/profile

# ===== Anti-baneo / comportamiento humano =====
HUMAN_MIN_DELAY=0.4
HUMAN_MAX_DELAY=1.2
LISTING_MIN_GAP=25
LISTING_MAX_GAP=70
MAX_LISTINGS_PER_DAY=20
MAX_RETRIES=2

# ===== Marketplace =====
DEFAULT_CATEGORY=Juguetes y juegos
DEFAULT_CONDITION=Nuevo
